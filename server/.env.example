# Port the server listens on (most hosts inject PORT automatically).
PORT=2567

# Set to "production" in production deployments.
NODE_ENV=development

# Comma-separated list of allowed browser origins for CORS in production.
# Example: https://iskaworld.vercel.app,https://www.yourdomain.com
# Leave empty in dev to allow all origins.
CLIENT_ORIGIN=

# Credentials to protect the /monitor dashboard.
# In production the monitor is ONLY exposed when both are set.
MONITOR_USER=admin
MONITOR_PASS=change-me
